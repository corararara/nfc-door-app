<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0a0a0f">

    <TextView
        android:text="🔑 NFC Tür"
        android:textSize="32sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/cardInfoText"
        android:text="Aktive UID: EC 4A 5C 14"
        android:textSize="13sp"
        android:textColor="#4f6ef7"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/statusText"
        android:text="✅ Bereit"
        android:textSize="15sp"
        android:textColor="#e8e8f0"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/toggleButton"
        android:text="Tür öffnen"
        android:textSize="18sp"
        android:textColor="#ffffff"
        android:backgroundTint="#4f6ef7"
        android:layout_width="280dp"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/scanButton"
        android:text="📶 Karte scannen"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:backgroundTint="#1a1a28"
        android:layout_width="280dp"
        android:layout_height="56dp"/>

</LinearLayout>
